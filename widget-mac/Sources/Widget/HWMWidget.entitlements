<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox only. The Electron app mirrors latest.json into THIS extension's
	     sandbox container (~/Library/Containers/<ext-id>/Data/), which a sandboxed
	     widget can always read — no app group / dev certificate required. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
</dict>
</plist>
