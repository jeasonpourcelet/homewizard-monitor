# Dependencies
node_modules/

# Build output (electron-builder) — contains absolute machine paths, never commit
dist/
out/

# .NET / widget build output
**/bin/
**/obj/
**/AppPackages/
*.user

# macOS widget (Xcode): generated project + build output (regenerated from project.yml)
widget-mac/*.xcodeproj/
widget-mac/build/
widget-mac/DerivedData/
*.xcuserstate

# Local runtime data & logs
*.log
*.tmp
hwm-diag.log

# Generated icons are committed (small, reproducible via `npm run icons`),
# but ignore any throwaway exports
*.icns

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
